# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=offerwall_sdkless_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# Portal base URL (used for QR generation)
PORTAL_BASE_URL=https://portal.offerwall.com

# Base URL (for constructing public URLs to API resources)
BASE_URL=http://localhost:3000

# QR images directory
QR_IMAGES_DIR=/tmp/qr_images_sdkless
